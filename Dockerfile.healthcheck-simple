FROM node:18-alpine

WORKDIR /app

# Copy health check file
COPY healthcheck-simple.js .

# Create a minimal package.json
RUN echo '{"name":"healthcheck","version":"1.0.0","main":"healthcheck-simple.js","dependencies":{"express":"4.18.2"}}' > package.json

# Install only express dependency
RUN npm install express --production

# Expose health check port
EXPOSE 3001

# Start health check service
CMD ["node", "healthcheck-simple.js"]
